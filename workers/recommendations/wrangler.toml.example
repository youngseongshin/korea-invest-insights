name = "korea-invest-insights-recommendations"
main = "src/worker.js"
compatibility_date = "2026-05-16"

# Preferred: route this Worker to the same origin used by the Hugo widget.
# This requires the domain to be a proxied Cloudflare zone, for example:
# routes = [
#   { pattern = "koreainvestinsights.com/api/recommendations", custom_domain = false }
# ]
#
# Fallback: deploy to workers.dev and set HUGO_RECOMMENDATIONS_API to that
# workers.dev endpoint. Keep ALLOWED_ORIGINS restricted to the live site.
# workers_dev = true

[[d1_databases]]
binding = "DB"
database_name = "korea-invest-insights-recommendations"
database_id = "replace-with-cloudflare-d1-database-id"

[vars]
ALLOWED_ORIGINS = "https://koreainvestinsights.com,https://www.koreainvestinsights.com,http://localhost:1313"
